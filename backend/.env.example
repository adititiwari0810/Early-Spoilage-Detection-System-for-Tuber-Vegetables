# Server
PORT=4000
NODE_ENV=development

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=potato/node

# InfluxDB
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=potato-influx-token-2024
INFLUX_ORG=potato_org
INFLUX_BUCKET=sensor_data

# PostgreSQL
PG_HOST=localhost
PG_PORT=5433
PG_USER=potato_user
PG_PASSWORD=potato_pg_pass
PG_DATABASE=potato_spoilage

# Alert Thresholds (warning / critical)
ALERT_TEMP_WARNING=28
ALERT_TEMP_CRITICAL=35
ALERT_HUM_WARNING=90
ALERT_HUM_CRITICAL=95
ALERT_CO2_WARNING=2000
ALERT_CO2_CRITICAL=3500
ALERT_ETH_WARNING=5
ALERT_ETH_CRITICAL=15
ALERT_SCORE_WARNING=0.5
ALERT_SCORE_CRITICAL=0.75

# Analysis
ROLLING_WINDOW_SIZE=50
EMA_ALPHA=0.2
ZSCORE_THRESHOLD=2
SLOPE_WINDOW=10
NODE_OFFLINE_MINUTES=5

# Batch Job
BATCH_CRON=*/15 * * * *
